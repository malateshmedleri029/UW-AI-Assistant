# ==========================================
# UW Smart AI Assistant — .gitignore
# ==========================================

# ---- SECRETS (never commit) ----
backend/.env
*.env
*.env.local
*.env.production

# ---- Python ----
backend/.venv/
backend/venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so

# ---- Python test / coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---- ADK / SQLite sessions ----
backend/sessions.db
backend/*.db
backend/*.db-shm
backend/*.db-wal

# ---- Node / Angular ----
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.sass-cache/

# ---- OS files ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Build artifacts ----
*.tgz
*.tar.gz
